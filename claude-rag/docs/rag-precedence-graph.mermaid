flowchart TD
    START(("🚀 START"))

    M0["✅ M0: Environment Ready"]
    M1["✅ M1: Parser & Chunker Ready"]
    M2["✅ M2: File Watcher Ready"]
    M3["✅ M3: Embedding Module Ready"]
    M4["✅ M4: DB Schema & Storage Ready"]
    M5["✅ M5: E2E Ingestion Works"]
    M6["✅ M6: Semantic Search Works"]
    M7["✅ M7: Hybrid Search Works"]
    M8["✅ M8: Search Pipeline Complete"]
    M9["✅ M9: MCP Server Operational"]
    M10["✅ M10: RAG-First Workflow Active"]
    M11["✅ M11: Enrichment Active"]
    M12["✅ M12: Embeddings Swappable"]
    M13["✅ M13: Production Ready"]
    DONE(("🏁 DONE"))

    START -->|"T0.1-0.3: Python project + PG + pgvector"| M0

    M0 -->|"T1.1-1.4: Memory parser & chunker"| M1
    M0 -->|"T3.1-3.3: Embedding model & interface"| M3
    M0 -->|"T4.1-4.4: Schema, storage, tsvector"| M4

    M1 -->|"T2.1-2.3: Watchdog + change detect"| M2

    M2 -->|"T5.1-5.2: Wire ingestion pipeline"| M5
    M3 -.->|"embed chunks"| M5
    M4 -.->|"store chunks"| M5

    M3 -.->|"embed queries"| M6
    M4 -->|"T6.1-6.2: Semantic search + eval"| M6

    M6 -->|"T7.1-7.3: Keyword search + RRF"| M7

    M7 -->|"T8.1-8.3: Dedup + token budget"| M8

    M8 -->|"T9.1-9.3: MCP server + config"| M9

    M9 -->|"T10.1-10.3: CLAUDE.md RAG-first"| M10

    M5 -.->|"data available"| M11
    M10 -->|"T11.1-11.3: Metadata + filters"| M11

    M3 -->|"T12.1-12.2: API provider + migration"| M12

    M10 -->|"T13.1-13.3: Logging + health + perf"| M13

    M11 --> DONE
    M12 --> DONE
    M13 --> DONE

